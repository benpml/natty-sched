{
  "name": "natty-sched",
  "version": "1.3.3",
  "description": "Natural language scheduler with autocomplete - Parse human-readable schedules to JSON, calculate next run times, and get smart suggestions. Supports 'every 3 days', 'weekdays at 9am', 'first Monday of month', with typo tolerance and 95+ templates.",
  "main": "index.js",
  "unpkg": "dist/natty-sched.umd.js",
  "browser": "dist/natty-sched.umd.js",
  "scripts": {
    "build:umd": "webpack --config webpack.umd.config.js",
    "test": "node test.js && node test-comprehensive.js && node test-calculator.js && node test-autocomplete-comprehensive.js && node test-validation.js"
  },
  "keywords": [
    "scheduler",
    "cron",
    "natural-language",
    "parser",
    "schedule",
    "nlp",
    "time",
    "recurring",
    "interval",
    "human-readable",
    "date-parser",
    "calendar",
    "scheduling",
    "task-scheduler",
    "cron-alternative",
    "flexible-scheduling",
    "typo-tolerant"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/benpml/natty-sched.git"
  },
  "bugs": {
    "url": "https://github.com/benpml/natty-sched/issues"
  },
  "homepage": "https://github.com/benpml/natty-sched#readme",
  "engines": {
    "node": ">=12.0.0"
  },
  "files": [
    "index.js",
    "src/",
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "browserify": "^17.0.1",
    "webpack": "^5.105.2",
    "webpack-cli": "^6.0.1"
  }
}
